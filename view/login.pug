doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Login
    link(rel="stylesheet", href="/login.css")
    // Font Awesome để có icon
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css")
  body
    .login-container
      h2 Đăng nhập
      form.login-form(action="/login" method="post")
        .input-group
          span.icon
            i.fa.fa-user
          input(type="text" placeholder="Username" name="username")
        .input-group
          span.icon
            i.fa.fa-lock
          input(type="password" placeholder="Password" name="password")
        input.btn(type="submit" value="Đăng Nhập")
      .links
        a(href="#") Quên mật khẩu?
        |  hoặc 
        a(href="#" id="openRegister") Đăng ký




    .overlay#registerOverlay(style="display:none")
    .register-modal#registerModal(style="display:none")
      h2.form-title Đăng ký tài khoản
      form(action="/register" method="POST" class="register-form")
        .form-group
          label(for="username") Tên đăng nhập
          input(type="text" name="username" placeholder="Nhập tên đăng nhập..." required)

        .form-group
          label(for="fullname") Họ và tên
          input(type="text" name="fullname" placeholder="Nhập họ và tên..." required)

        .form-group
          label(for="password") Mật khẩu
          input(type="password" name="password" placeholder="Nhập mật khẩu..." required)

        input(type="hidden" name="role" value="student")

        .form-actions
          button.btn.cancel(type="button" id="closeRegister")
            i(class="fa-solid fa-xmark")
            |  Hủy
          button.btn.save(type="submit")
            i(class="fa-solid fa-user-plus")
            |  Đăng ký

    script(src="/register-popup.js")
